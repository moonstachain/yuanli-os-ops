{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "weekly_scorecard",
  "type": "object",
  "required": ["round_id", "generated_at", "collector_score", "workflow_scores", "selection_outlook"],
  "properties": {
    "round_id": {"type": "string"},
    "generated_at": {"type": "string"},
    "collector_score": {
      "type": "object",
      "required": ["total", "breakdown", "redlines", "training_backlog"],
      "properties": {
        "total": {"type": "number"},
        "breakdown": {"type": "object"},
        "redlines": {
          "type": "array",
          "items": {"type": "string"}
        },
        "training_backlog": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "workflow_scores": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "required": [
          "workflow_name",
          "total",
          "breakdown",
          "redlines",
          "training_backlog",
          "platform_fit_assessment"
        ],
        "properties": {
          "workflow_name": {"type": "string"},
          "total": {"type": "number"},
          "breakdown": {"type": "object"},
          "platform_fit_assessment": {
            "type": "object",
            "required": ["declared_path", "assessment_note"],
            "properties": {
              "declared_path": {"type": "string"},
              "assessment_note": {"type": "string"}
            }
          },
          "redlines": {
            "type": "array",
            "items": {"type": "string"}
          },
          "training_backlog": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      }
    },
    "selection_outlook": {
      "type": "object",
      "required": ["leaderboard", "current_leader", "notes"],
      "properties": {
        "leaderboard": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": {"type": "string"}
        },
        "current_leader": {"type": "string"},
        "notes": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    }
  }
}
